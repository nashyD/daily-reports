# Copy to .env and fill in. .env is gitignored — it never leaves your machine.
# The daily podcast step (scripts/make-podcast.mjs) reads these.

# Required: a Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional overrides (defaults shown)
# PODCAST_TTS_MODEL=gemini-2.5-flash-preview-tts
# PODCAST_HOST_A=Alex
# PODCAST_HOST_B=Sam
# PODCAST_VOICE_A=Puck
# PODCAST_VOICE_B=Kore
# PODCAST_KEEP=60
